---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Custom Orders">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <p class="font-script text-2xl text-sage-700 mb-1">made just for you</p>
      <h1 class="text-5xl md:text-6xl mb-4">Custom Orders</h1>
      <p class="text-earth-800/80 text-lg max-w-2xl mx-auto">
        Wedding cakes, large pastry orders, corporate gifting, or anything
        not on the standard menu — tell us what you have in mind.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 mb-12">
      <div class="bg-cream-100 p-6 rounded-lg text-center">
        <div class="text-3xl mb-2">💒</div>
        <h3 class="font-serif text-lg font-semibold mb-1">Weddings</h3>
        <p class="text-sm text-earth-800/80">
          Custom tiered cakes. Book 6+ weeks ahead.
        </p>
      </div>
      <div class="bg-cream-100 p-6 rounded-lg text-center">
        <div class="text-3xl mb-2">🎂</div>
        <h3 class="font-serif text-lg font-semibold mb-1">Celebrations</h3>
        <p class="text-sm text-earth-800/80">
          Birthdays, anniversaries, just-because cakes.
        </p>
      </div>
      <div class="bg-cream-100 p-6 rounded-lg text-center">
        <div class="text-3xl mb-2">📦</div>
        <h3 class="font-serif text-lg font-semibold mb-1">Bulk & Corporate</h3>
        <p class="text-sm text-earth-800/80">
          Trays of pastries, gift boxes, office orders.
        </p>
      </div>
    </div>

    <form class="bg-white border border-cream-200 rounded-lg p-8 space-y-6">
      <div class="bg-cream-100 text-earth-800 text-sm px-4 py-3 rounded">
        ⚠️ Form is not wired up yet — will connect to Formspree in Phase 2.
      </div>

      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label for="name" class="block text-sm font-medium mb-1">Your name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full px-4 py-2 border border-cream-200 rounded focus:outline-none focus:ring-2 focus:ring-sage-700/30"
          />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium mb-1">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-2 border border-cream-200 rounded focus:outline-none focus:ring-2 focus:ring-sage-700/30"
          />
        </div>
      </div>

      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label for="phone" class="block text-sm font-medium mb-1">Phone (optional)</label>
          <input
            type="tel"
            id="phone"
            name="phone"
            class="w-full px-4 py-2 border border-cream-200 rounded focus:outline-none focus:ring-2 focus:ring-sage-700/30"
          />
        </div>
        <div>
          <label for="event-date" class="block text-sm font-medium mb-1">Event date</label>
          <input
            type="date"
            id="event-date"
            name="event-date"
            class="w-full px-4 py-2 border border-cream-200 rounded focus:outline-none focus:ring-2 focus:ring-sage-700/30"
          />
        </div>
      </div>

      <div>
        <label for="order-type" class="block text-sm font-medium mb-1">Order type</label>
        <select
          id="order-type"
          name="order-type"
          class="w-full px-4 py-2 border border-cream-200 rounded focus:outline-none focus:ring-2 focus:ring-sage-700/30"
        >
          <option>Wedding cake</option>
          <option>Celebration cake</option>
          <option>Bulk pastries</option>
          <option>Corporate / gifting</option>
          <option>Something else</option>
        </select>
      </div>

      <div>
        <label for="details" class="block text-sm font-medium mb-1">
          Tell us about your order
        </label>
        <textarea
          id="details"
          name="details"
          rows="5"
          placeholder="Flavors, dietary needs, serving size, inspiration photos welcome..."
          class="w-full px-4 py-2 border border-cream-200 rounded focus:outline-none focus:ring-2 focus:ring-sage-700/30"
        ></textarea>
      </div>

      <button
        type="submit"
        disabled
        class="w-full bg-cream-200 text-earth-800/60 cursor-not-allowed px-6 py-3 rounded-full font-medium"
      >
        Send inquiry (form not yet active)
      </button>
    </form>
  </section>
</BaseLayout>
