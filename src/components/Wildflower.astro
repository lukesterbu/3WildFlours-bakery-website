---
interface Props {
  class?: string;
  size?: number;
}

const { class: className = "", size = 32 } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 64 64"
  fill="none"
  stroke="currentColor"
  stroke-width="1.4"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  <!-- Stem -->
  <path d="M32 58 V 28" />
  <!-- Left leaf -->
  <path d="M32 46 C 26 44 22 40 22 36" />
  <path d="M22 36 C 26 38 30 40 32 42" />
  <!-- Right leaf -->
  <path d="M32 40 C 38 38 42 34 42 30" />
  <path d="M42 30 C 38 32 34 34 32 36" />
  <!-- Flower head: 6 petals around a center -->
  <circle cx="32" cy="22" r="3" fill="currentColor" stroke="none" opacity="0.85" />
  <ellipse cx="32" cy="14" rx="2.2" ry="4.5" />
  <ellipse cx="40" cy="18" rx="4.5" ry="2.2" transform="rotate(45 40 18)" />
  <ellipse cx="40" cy="26" rx="2.2" ry="4.5" transform="rotate(45 40 26)" />
  <ellipse cx="32" cy="30" rx="2.2" ry="4.5" />
  <ellipse cx="24" cy="26" rx="4.5" ry="2.2" transform="rotate(45 24 26)" />
  <ellipse cx="24" cy="18" rx="2.2" ry="4.5" transform="rotate(45 24 18)" />
</svg>
